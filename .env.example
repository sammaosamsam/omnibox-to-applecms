# ────────────────────────────────────────────────
# OmniBox to AppleCMS - 环境变量配置
# ────────────────────────────────────────────────
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# ────────────────────────────────────────────────

# 服务端口（服务器对外端口）
PORT=3033

# 日志级别：debug, info, warn, error
LOG_LEVEL=info

# ── 安全配置（必填）──────────────────────────────
# ⚠️ 生产环境必须设置复杂密钥！
# 生成随机密钥：openssl rand -hex 32
ADMIN_API_KEY=your-secret-api-key-here

# ── 镜像版本（可选）──────────────────────────────
# 用于指定特定版本，如不设置则使用 latest
# IMAGE_TAG=v1.0.0
